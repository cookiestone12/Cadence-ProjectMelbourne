# ==============================================
# Ampersound Platform — Environment Variables
# ==============================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] must be set for the
# application to start. All others are optional.
# ==============================================

# ======================
# Database [REQUIRED]
# ======================
DATABASE_URL=postgresql://user:password@localhost:5432/ampersound

# ======================
# Authentication [REQUIRED]
# ======================
# Used for JWT signing — must be a strong random string
SESSION_SECRET=your-secret-key-here

# ======================
# Server Configuration
# ======================
PORT=8000
WEB_CONCURRENCY=4
LOG_LEVEL=INFO
# Log output format: "text" (human-readable) or "json" (structured)
LOG_FORMAT=text
# Comma-separated list of allowed CORS origins ("*" allows all)
CORS_ORIGINS=*
# Set to "true" to enable SQLAlchemy SQL statement logging
SQL_DEBUG=false

# ======================
# Spotify Integration (optional)
# ======================
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ======================
# OpenAI / AI Integration (optional)
# ======================
# Managed automatically by Replit AI Integrations when available.
# Set manually only if running outside Replit.
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ======================
# Chartmetric Integration (optional)
# ======================
CHARTMETRIC_API_KEY=

# ======================
# Luminate Integration (optional)
# ======================
LUMINATE_API_KEY=
LUMINATE_API_SECRET=

# ======================
# Claude / Additional AI (optional)
# ======================
CLAUDE_API_KEY=
