modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["python_database:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "backend"

[[workflows.workflow]]
name = "frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash run_backend.sh"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 35329
externalPort = 6800

[[ports]]
localPort = 36423
externalPort = 3001

[[ports]]
localPort = 36849
externalPort = 3000

[[ports]]
localPort = 37807
externalPort = 5173

[[ports]]
localPort = 38959
externalPort = 8008

[[ports]]
localPort = 39399
externalPort = 5000

[[ports]]
localPort = 39847
externalPort = 6000

[[ports]]
localPort = 44379
externalPort = 4200

[[ports]]
localPort = 45937
externalPort = 3003

[[ports]]
localPort = 46603
externalPort = 8080

[nix]
channel = "stable-25_05"

[deployment]
build = ["sh", "-c", "cd frontend && npm run build"]
run = ["python", "-m", "uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "5000"]
deploymentTarget = "autoscale"
